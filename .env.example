# Copy this file to .env and fill in your API keys
# This file should NOT be committed to version control

# Finnhub API (optional - for alternative news sources)
# Get free API key from https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI (optional - for detailed news analysis)
# Get free API key from https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# WebUll (if you have dev credentials)
WEBULL_API_KEY=your_webull_api_key_here

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Email notifications (optional)
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password

# Telegram bot (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Discord webhook (optional)
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=your_discord_webhook_url
